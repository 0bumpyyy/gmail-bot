datasource db {
  provider = "postgresql"  // ← вместо sqlite
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

generator db {
  provider = "prisma-client-js"
  // Удалите автоматические миграции
}

model User {
  id           Int      @id @default(autoincrement())
  telegramId   String   @unique
  token        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EmailAccount {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password     String
  isActive     Boolean  @default(true)
  csvName      String?
  recipients   String?  // Список email-адресов через запятую
  currentIndex Int      @default(0)
  telegramId   String   // К какому Telegram-аккаунту привязана эта почта
}

model Template {
  id         Int      @id @default(autoincrement())
  telegramId String
  platform   String   @default("DEPOP") // 👈 Новое поле для группировки (DEPOP, POSHMARK, ETSY)
  name       String
  type       String
  link       String?
  subject    String?
  body       String?
  senderName String?
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([telegramId, platform, name]) // 👈 Индекс теперь учитывает и площадку
  @@index([telegramId])
}

model Log {
  id        Int      @id @default(autoincrement())
  fromEmail String
  toEmail   String
  status    String   // "SUCCESS" или "ERROR"
  errorMsg  String?
  sentAt    DateTime @default(now())
}

model SystemState {
  id        Int     @id @default(1)
  isMailingActive Boolean @default(false) // Тот самый глобальный рубильник
}